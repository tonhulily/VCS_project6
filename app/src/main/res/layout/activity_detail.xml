<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
    <data>
        <variable
            name="place"
            type="com.example.vcs_project6.data.model.Place"/>
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F2">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">
                <ImageView
                    android:id="@+id/imgDetail"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_overlay"/>
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_back"
                    android:contentDescription="@string/back"/>
                <ImageButton
                    android:id="@+id/btnFavorite"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_heart_outline"
                    android:contentDescription="@string/save_place"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                android:text="@{place.name}"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#222222"/>
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:text="@{place.shortDescription}"
                android:textSize="15sp"
                android:textColor="#FF6F00"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:padding="20dp"
                android:gravity="center">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_time"
                        android:contentDescription="@null"/>
                    <TextView
                        android:id="@+id/tvBestTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{place.bestTime}"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:maxLines="2"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_duration"
                        android:contentDescription="@null"/>
                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{place.duration}"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:maxLines="2"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ticket"
                        android:contentDescription="@null"/>
                    <TextView
                        android:id="@+id/tvTicket"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{place.ticketPrice}"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:maxLines="2"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/introduction"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:paddingHorizontal="20dp"/>
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@{place.fullDescription}"
                android:padding="20dp"
                android:textColor="#555555"
                android:lineSpacingExtra="6dp"/>
            <Button
                android:id="@+id/btnMap"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_margin="20dp"
                android:text="@string/view_on_map"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button"/>
        </LinearLayout>
    </ScrollView>
</layout>